// Cyclic rotation formulaes 

Method 1 :
// Upto r - l length
ll len = r - l;

for(i = l; i < r; i++)
    p[i] = l + ((i - l + 1) % len) + 1;

Method 2 : 
// Upto r - l length
for(i = l; i < r - 1; i++)
    p[i] = i + 2;

p[r - 1] = l + 1;

Method 3 :
// For the whole array 

for(i = 0; i < n; i++)
    p[i] = (i + 1) % n;
